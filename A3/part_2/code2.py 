class PromptUtils:
    """Utility class to construct prompts with tools and queries."""
    
    def __init__(self, tools: List[Dict]):
        self.tools = tools
    
    def construct_prompt(self, query: str, tool_order: Optional[List[int]] = None) -> str:
        """
        Construct a prompt with all tools followed by the query.
        
        Args:
            query: The query string
            tool_order: Optional ordering of tools (for position experiments)
        
        Returns:
            Full prompt string
        """
        if tool_order is None:
            tool_order = list(range(len(self.tools)))
        
        prompt_parts = []
        prompt_parts.append("Below is a list of available tools:\n\n")
        
        for i, idx in enumerate(tool_order):
            tool = self.tools[idx]
            prompt_parts.append(f"Tool {i+1}: {tool['name']}\n")
            prompt_parts.append(f"Description: {tool['description']}\n\n")
        
        prompt_parts.append(f"Query: {query}\n")
        prompt_parts.append("Which tool should be used for this query?")
        
        return "".join(prompt_parts)
    
    def get_doc_spans(
        self, 
        tokenizer, 
        prompt: str, 
        tool_order: Optional[List[int]] = None
    ) -> List[Tuple[int, int, int]]:
        """
        Get the token spans for each tool in the prompt.
        
        Args:
            tokenizer: The tokenizer
            prompt: The full prompt
            tool_order: Tool ordering used in the prompt
        
        Returns:
            List of (tool_idx, start_token, end_token) tuples
        """
        if tool_order is None:
            tool_order = list(range(len(self.tools)))
        
        doc_spans = []
        
        # Tokenize full prompt
        full_tokens = tokenizer.encode(prompt, add_special_tokens=False)
        
        # Find each tool's span
        current_pos = 0
        prefix = "Below is a list of available tools:\n\n"
        prefix_tokens = tokenizer.encode(prefix, add_special_tokens=False)
        current_pos = len(prefix_tokens)
        
        for i, idx in enumerate(tool_order):
            tool = self.tools[idx]
            tool_text = f"Tool {i+1}: {tool['name']}\nDescription: {tool['description']}\n\n"
            tool_tokens = tokenizer.encode(tool_text, add_special_tokens=False)
            
            start_pos = current_pos
            end_pos = current_pos + len(tool_tokens)
            
            doc_spans.append((idx, start_pos, end_pos))
            current_pos = end_pos
        
        return doc_spans


