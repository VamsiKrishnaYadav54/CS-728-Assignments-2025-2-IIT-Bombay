#!/usr/bin/env python3
"""
Part 1: Classical Retrieval Methods
- BM25 (sparse retrieval)
- msmarco-MiniLM (dense retrieval)
- UAE-Large-V1 (dense retrieval)

Computes Recall@1 and Recall@5 for each method.
"""

import json
import numpy as np
from typing import List, Dict, Tuple
from pathlib import Path
import torch
from tqdm import tqdm

# BM25
from rank_bm25 import BM25Okapi
import nltk
from nltk.tokenize import word_tokenize

# Dense retrieval
from sentence_transformers import SentenceTransformer

# Ensure nltk data is available
try:
    nltk.data.find('tokenizers/punkt')
except LookupError:
    nltk.download('punkt', quiet=True)
try:
    nltk.data.find('tokenizers/punkt_tab')
except LookupError:
    nltk.download('punkt_tab', quiet=True)


def load_data(data_dir: str = "data") -> Tuple[List[Dict], List[Dict], List[Dict]]:
    """Load tools and queries from JSON files."""
    data_path = Path(data_dir)
    
    with open(data_path / "tools.json", "r") as f:
        tools = json.load(f)
    
    with open(data_path / "train_queries.json", "r") as f:
        train_queries = json.load(f)
    
    with open(data_path / "test_queries.json", "r") as f:
        test_queries = json.load(f)
    
    return tools, train_queries, test_queries


def get_tool_texts(tools: List[Dict]) -> List[str]:
    """Extract text representation of each tool (name + description)."""
    tool_texts = []
    for tool in tools:
        # Combine name and description for retrieval
        text = f"{tool['name']}: {tool['description']}"
        tool_texts.append(text)
    return tool_texts


def compute_recall(rankings: List[List[int]], gold_indices: List[int], k: int) -> float:
    """
    Compute Recall@k.
    
    Args:
        rankings: For each query, a list of tool indices ranked by relevance
        gold_indices: For each query, the index of the correct tool
        k: Top-k to consider
    
    Returns:
        Recall@k score
    """
    hits = 0
    for ranking, gold_idx in zip(rankings, gold_indices):
        if gold_idx in ranking[:k]:
            hits += 1
    return hits / len(gold_indices)


# =============================================================================
# BM25 Retrieval
# =============================================================================

def bm25_retrieval(tool_texts: List[str], queries: List[Dict]) -> Tuple[List[List[int]], List[int]]:
    """
    BM25 sparse retrieval.
    
    Args:
        tool_texts: Text representation of each tool
        queries: List of query dictionaries
    
    Returns:
        rankings: For each query, ranked list of tool indices
        gold_indices: For each query, the correct tool index
    """
    print("Running BM25 retrieval...")
    
    # Tokenize documents
    tokenized_corpus = [word_tokenize(doc.lower()) for doc in tool_texts]
    bm25 = BM25Okapi(tokenized_corpus)
    
    rankings = []
    gold_indices = []
    
    for query_data in tqdm(queries, desc="BM25"):
        query_text = query_data["query"]
        gold_tool = query_data["tool"]  # This might be tool name or index
        
        # Find gold index
        if isinstance(gold_tool, int):
            gold_idx = gold_tool
        else:
            # Find by name
            gold_idx = next(i for i, t in enumerate(tool_texts) if gold_tool in t)
        gold_indices.append(gold_idx)
        
        # Tokenize query
        tokenized_query = word_tokenize(query_text.lower())
        
        # Get BM25 scores
        scores = bm25.get_scores(tokenized_query)
        
        # Rank by score (descending)
        ranked_indices = np.argsort(scores)[::-1].tolist()
        rankings.append(ranked_indices)
    
    return rankings, gold_indices


# =============================================================================
# Dense Retrieval (MiniLM and UAE)
# =============================================================================

def dense_retrieval(
    tool_texts: List[str], 
    queries: List[Dict],
    model_name: str,
    batch_size: int = 32
) -> Tuple[List[List[int]], List[int]]:
    """
    Dense retrieval using sentence transformers.
    
    Args:
        tool_texts: Text representation of each tool
        queries: List of query dictionaries
        model_name: HuggingFace model name
        batch_size: Batch size for encoding
    
    Returns:
        rankings: For each query, ranked list of tool indices
        gold_indices: For each query, the correct tool index
    """
    print(f"Running dense retrieval with {model_name}...")
    
    # Load model
    device = "cuda" if torch.cuda.is_available() else "cpu"
    model = SentenceTransformer(model_name, device=device)
    
    # Encode all tools
    print("Encoding tools...")
    tool_embeddings = model.encode(
        tool_texts, 
        batch_size=batch_size, 
        show_progress_bar=True,
        convert_to_tensor=True
    )
    
    rankings = []
    gold_indices = []
    
    # Process queries
    query_texts = [q["query"] for q in queries]
    
    print("Encoding queries...")
    query_embeddings = model.encode(
        query_texts,
        batch_size=batch_size,
        show_progress_bar=True,
        convert_to_tensor=True
    )
    
    print("Computing rankings...")
    for i, query_data in enumerate(tqdm(queries, desc="Ranking")):
        gold_tool = query_data["tool"]
        
        # Find gold index
        if isinstance(gold_tool, int):
            gold_idx = gold_tool
        else:
            gold_idx = next(j for j, t in enumerate(tool_texts) if gold_tool in t)
        gold_indices.append(gold_idx)
        
        # Compute cosine similarity
        query_emb = query_embeddings[i]
        similarities = torch.nn.functional.cosine_similarity(
            query_emb.unsqueeze(0), 
            tool_embeddings
        )
        
        # Rank by similarity (descending)
        ranked_indices = torch.argsort(similarities, descending=True).cpu().tolist()
        rankings.append(ranked_indices)
    
    return rankings, gold_indices


def main():
    print("=" * 60)
    print("Part 1: Classical Retrieval")
    print("=" * 60)
    
    # Load data
    print("\nLoading data...")
    tools, train_queries, test_queries = load_data()
    print(f"Loaded {len(tools)} tools")
    print(f"Loaded {len(train_queries)} training queries")
    print(f"Loaded {len(test_queries)} test queries")
    
    # Get tool texts
    tool_texts = get_tool_texts(tools)
    
    # Results dictionary
    results = {}
    
    # ==========================================================================
    # Method 1: BM25
    # ==========================================================================
    print("\n" + "-" * 40)
    print("Method 1: BM25")
    print("-" * 40)
    
    rankings, gold_indices = bm25_retrieval(tool_texts, test_queries)
    
    recall_1 = compute_recall(rankings, gold_indices, k=1)
    recall_5 = compute_recall(rankings, gold_indices, k=5)
    
    results["BM25"] = {"Recall@1": recall_1, "Recall@5": recall_5}
    print(f"Recall@1: {recall_1:.4f}")
    print(f"Recall@5: {recall_5:.4f}")
    
    # ==========================================================================
    # Method 2: msmarco-MiniLM
    # ==========================================================================
    print("\n" + "-" * 40)
    print("Method 2: msmarco-MiniLM")
    print("-" * 40)
    
    rankings, gold_indices = dense_retrieval(
        tool_texts, 
        test_queries,
        model_name="sentence-transformers/msmarco-MiniLM-L-6-v2"
    )
    
    recall_1 = compute_recall(rankings, gold_indices, k=1)
    recall_5 = compute_recall(rankings, gold_indices, k=5)
    
    results["msmarco-MiniLM"] = {"Recall@1": recall_1, "Recall@5": recall_5}
    print(f"Recall@1: {recall_1:.4f}")
    print(f"Recall@5: {recall_5:.4f}")
    
    # ==========================================================================
    # Method 3: UAE-Large-V1
    # ==========================================================================
    print("\n" + "-" * 40)
    print("Method 3: UAE-Large-V1")
    print("-" * 40)
    
    rankings, gold_indices = dense_retrieval(
        tool_texts, 
        test_queries,
        model_name="WhereIsAI/UAE-Large-V1"
    )
    
    recall_1 = compute_recall(rankings, gold_indices, k=1)
    recall_5 = compute_recall(rankings, gold_indices, k=5)
    
    results["UAE-Large-V1"] = {"Recall@1": recall_1, "Recall@5": recall_5}
    print(f"Recall@1: {recall_1:.4f}")
    print(f"Recall@5: {recall_5:.4f}")
    
    # ==========================================================================
    # Summary
    # ==========================================================================
    print("\n" + "=" * 60)
    print("Part 1 Results Summary")
    print("=" * 60)
    print(f"{'Method':<20} {'Recall@1':<12} {'Recall@5':<12}")
    print("-" * 44)
    for method, scores in results.items():
        print(f"{method:<20} {scores['Recall@1']:<12.4f} {scores['Recall@5']:<12.4f}")
    
    # Save results
    with open("results/part1_results.json", "w") as f:
        json.dump(results, f, indent=2)
    print("\nResults saved to results/part1_results.json")


if __name__ == "__main__":
    main()
